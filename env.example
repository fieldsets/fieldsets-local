#!/usr/bin/env bash
# Copy this file to .env in this directory. These are all default values (unless specified in an adjacent comment otherwise) and will be set even if not defined in .env

# This allows you to use multiple compose files found in /config/docker/
COMPOSE_PATH_SEPARATOR=:
COMPOSE_FILE=docker-compose.yml

# Local user ids to manage permissions
LOCAL_UID=1000
LOCAL_GID=1000

CLICKHOUSE_USER=fieldsets
CLICKHOUSE_PASSWORD=fieldsets
CLICKHOUSE_HOST=172.28.0.5
CLICKHOUSE_PORT=8123

POSTGRES_USER=fieldsets
POSTGRES_PASSWORD=fieldsets
POSTGRES_HOST=172.28.0.7
POSTGRES_PORT=5432

KAFKA_HOST=172.28.0.3
KAFKA_PORT=9092
ZOOKEEPER_PORT=2181

# Valid Time Zone strings found here https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/New_York

###################################################################################################################################
# No real need to edit or even include the variables below this line, but this serves as a complete list of working integrations. #
###################################################################################################################################

# Fieldsets major version Corresponds to changes in any versioning below.
FIELDSETS_VERSION=0.0.1

# Kafka can be used as a the fieldsets messages data store. This is currently the fieldsets-local default.
# TODO: Integrate Clickhouse native log table engine as default.
KAFKA_DATA_TOPIC=fieldsets_messages

CLICKOUSE_VERSION=22
CLICKHOUSE_DB=fieldsets

POSTGRES_VERSION=13
POSTGRES_DB=fieldsets
